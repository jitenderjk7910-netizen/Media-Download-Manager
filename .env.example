# -------------------------------------------------------
# Media Download Manager - Environment Configuration
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Web server
HOST=0.0.0.0
PORT=8080

# Authentication (leave blank for open/LAN access with no login)
USERNAME=admin
PASSWORD=changeme

# Session secret (auto-generated if blank — change for production!)
SESSION_SECRET=

# Allowed CORS origins (comma-separated, leave blank for same-origin only)
ALLOWED_ORIGINS=

# Tunnel URL to display on startup (Cloudflare, Tailscale, ngrok, etc.)
TUNNEL_URL=

# Rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=60

# Set to 1 to enable structured JSON logging to app.log
PRODUCTION=0

# Set to 1 to suppress automatic browser opening (always on in Docker)
NO_BROWSER=0
